# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.pytest_cache/

# Font build artifacts (user-installed OTF fallbacks) — exclude by default,
# but allow Source Han Serif K (OFL, bundled with the release) through.
assets/fonts/*.otf
!assets/fonts/SourceHanSerifKR-*.otf

# Template examples with placeholder content, regenerate via: python3 scripts/build.py
assets/examples/

/tmp/
/dist/*
!/dist/kami.zip
*.log
.vercel

# Slides build artifact (moved into assets/examples/ by build.py)
/output.pptx
